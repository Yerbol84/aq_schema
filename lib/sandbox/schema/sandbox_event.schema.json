{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aq:sandbox:event",
  "allOf": [
    { "$ref": "aq:sandbox:item" },
    {
      "type": "object",
      "required": ["sandboxId", "timestamp", "type", "severity"],
      "properties": {
        "sandboxId": { "type": "string" },
        "timestamp": { "type": "integer" },
        "type":      { "type": "string" },
        "severity":  { "type": "string",
                       "enum": ["debug","info","warning","error"] },
        "message":   { "type": "string" },
        "data":      { "type": "object" }
      }
    }
  ]
}