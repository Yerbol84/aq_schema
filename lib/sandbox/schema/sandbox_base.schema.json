{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "aq:sandbox:base",
  "type": "object",
  "required": ["sandboxId", "displayName", "sandboxType", "policy"],
  "properties": {
    "sandboxId":   { "type": "string" },
    "displayName": { "type": "string" },
    "sandboxType": {
      "type": "string",
      "enum": ["function", "process", "chat", "environment"]
    },
    "policy": { "$ref": "aq:sandbox:policy" }
  }
}