{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "aq:mcp:initialize",
  "title": "MCP Initialize Request",
  "description": "MCP protocol handshake request — strict MCP spec compliance",
  "type": "object",
  "required": ["jsonrpc", "method"],
  "properties": {
    "jsonrpc": {
      "type": "string",
      "const": "2.0"
    },
    "id": {
      "oneOf": [
        { "type": "string" },
        { "type": "integer" }
      ]
    },
    "method": {
      "type": "string",
      "const": "initialize"
    },
    "params": {
      "type": "object",
      "properties": {
        "protocolVersion": {
          "type": "string",
          "description": "MCP protocol version requested by client"
        },
        "capabilities": {
          "type": "object",
          "description": "Client capabilities"
        },
        "clientInfo": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "version": { "type": "string" }
          },
          "required": ["name", "version"]
        }
      }
    }
  },
  "additionalProperties": false
}
